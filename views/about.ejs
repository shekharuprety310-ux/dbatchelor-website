  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag"><i class="fas fa-heart"></i> Our Values</span>
      <h2 class="section-title">What <span class="highlight">Drives Us</span></h2>
    </div>
    <div class="grid-3 stagger">
      <div class="card text-center">
        <div class="service-icon" style="margin: 0 auto 1.25rem;">
          <i class="fas fa-star"></i>
        </div>
        <h3 style="margin-bottom:0.75rem;">Excellence</h3>
        <p style="color:var(--text-secondary);">We use premium equipment and deliver a flawless experience at every event, no matter the size.</p>
      </div>
      <div class="card text-center">
        <div class="service-icon" style="margin: 0 auto 1.25rem;">
          <i class="fas fa-handshake"></i>
        </div>
        <h3 style="margin-bottom:0.75rem;">Professionalism</h3>
        <p style="color:var(--text-secondary);">From first contact to pack-down, we're punctual, prepared, and professional every step of the way.</p>
      </div>
      <div class="card text-center">
        <div class="service-icon" style="margin: 0 auto 1.25rem;">
          <i class="fas fa-users"></i>
        </div>
