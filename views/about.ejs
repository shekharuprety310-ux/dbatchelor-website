<%- include('partials/header') %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content">
      <div class="breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>About Us</span></div>
      <h1 class="text-gradient">Meet Dale Batchelor</h1>
      <p style="color:var(--text-secondary); max-width:600px; margin: 1rem auto 0; font-size:1.1rem;">
        Professional DJ & Event Manager serving Tasmania since 2005
      </p>
    </div>
  </div>
</section>

<!-- Dale Profile Section -->
<section class="section">
  <div class="container">
    <div class="about-story-grid">
      <div class="reveal-left">
        <span class="section-tag"><i class="fas fa-user"></i> Meet Your DJ</span>
        <h2 class="section-title mt-2">Professional DJ <span class="highlight">Since 2005</span></h2>
        <p style="color:var(--text-secondary); line-height:1.9; margin:1.5rem 0;">
          Meet <strong>Dale Batchelor</strong> — the heart and soul behind D Batchelor Enterprises. With over 
          <strong>20 years of experience</strong> in the DJ industry, Dale has been bringing the party to life 
          across Tasmania since 2005.
        </p>
        <p style="color:var(--text-secondary); line-height:1.9; margin-bottom:1.5rem;">
          What started as a passion for music has evolved into one of Tasmania's most trusted entertainment 
          businesses. Dale's journey began in Hobart, and today he proudly serves the entire state — from 
          Launceston to Devonport, Burnie to the Tasman Peninsula.
        </p>
        <p style="color:var(--text-secondary); line-height:1.9; margin-bottom:1.5rem;">
          Whether it's a wedding reception, milestone birthday, corporate function, or school formal, Dale brings 
          the same dedication, energy, and professionalism to every event. His mission is simple: 
          <em>make your event unforgettable</em>.
        </p>
        <ul class="about-checklist">
          <li><i class="fas fa-check-circle"></i> Professional DJ since 2005</li>
          <li><i class="fas fa-check-circle"></i> 500+ Events Completed</li>
          <li><i class="fas fa-check-circle"></i> Serving all of Tasmania</li>
          <li><i class="fas fa-check-circle"></i> Full Event Management Services</li>
          <li><i class="fas fa-check-circle"></i> Premium Audio & Lighting Equipment</li>
        </ul>
      </div>
      <div class="reveal-right">
        <div class="about-logo-showcase">
          <div class="about-main-logo">
            <img src="/media/logos/logo-main.png" alt="D Batchelor Enterprises" style="width:100%; max-width:400px;">
          </div>
          <div class="dale-profile-card">
            <div class="dale-avatar">
              <img src="/media/events/dale-profile.png" alt="Dale Batchelor" style="width:100%;height:100%;object-fit:cover;">
            </div>
            <h3>Dale Batchelor</h3>
            <p class="dale-title">Owner & Principal DJ</p>
            <p class="dale-since">DJ since 2005</p>
            <div class="dale-stats">
              <div class="dale-stat">
                <span class="dale-stat-num">500+</span>
                <span class="dale-stat-label">Events</span>
              </div>
              <div class="dale-stat">
                <span class="dale-stat-num">20+</span>
                <span class="dale-stat-label">Years</span>
              </div>
            </div>
          </div>
          <div class="about-contact-card">
            <h4>Contact Dale Directly</h4>
            <div class="contact-item">
              <i class="fas fa-phone"></i>
              <a href="tel:0467764778">0467 764 778</a>
            </div>
            <div class="contact-item">
              <i class="fas fa-envelope"></i>
              <a href="mailto:dale@batchelorenterprises.com">dale@batchelorenterprises.com</a>
            </div>
            <div class="contact-item">
              <i class="fas fa-envelope"></i>
              <a href="mailto:cassandra@batchelorenterprises.com">cassandra@batchelorenterprises.com</a>
            </div>
            <div class="contact-item">
              <i class="fas fa-map-marker-alt"></i>
              <span>Based in Hobart, TAS</span>
            </div>
            <div class="contact-item">
              <i class="fas fa-briefcase"></i>
              <span>ABN: 61 924 754 338</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Values Section -->
