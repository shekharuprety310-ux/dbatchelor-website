<style>
.about-story-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.about-logo-showcase {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
}

.about-main-logo {
  background: transparent;
  border-radius: var(--radius);
  padding: 1.5rem;
  border: 1px solid rgba(10,125,232,0.2);
  width: 100%;
  display: flex;
  justify-content: center;
}

.about-main-logo img {
  filter: drop-shadow(0 0 20px var(--glow));
}

.about-contact-card {
  width: 100%;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.75rem;
}

.about-contact-card h4 {
  font-family: var(--font-heading);
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 0.85rem;
  margin-bottom: 0.85rem;
  color: var(--text-secondary);
  font-size: 0.95rem;
}

.contact-item i { color: var(--primary); margin-top: 0.15rem; flex-shrink: 0; }
.contact-item a { color: var(--text-secondary); }
.contact-item a:hover { color: var(--accent); }

.coverage-regions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
}

.tasmania-map-wrapper {
  max-width: 500px;
  margin: 0 auto 2rem;
  padding: 2rem;
  background: linear-gradient(135deg, var(--bg-card) 0%, rgba(94, 179, 255, 0.1) 100%);
  border: 2px solid var(--primary);
  border-radius: 20px;
  box-shadow: 0 0 40px rgba(94, 179, 255, 0.3);
}

.tasmania-map {
  width: 100%;
}

.tasmania-svg {
  width: 100%;
  height: auto;
}

.tasmania-island {
  fill: rgba(94, 179, 255, 0.15);
  stroke: var(--primary);
  stroke-width: 3;
}

.coastline {
  fill: none;
  stroke: var(--accent);
  stroke-width: 2;
  stroke-dasharray: 5,5;
}

.hq-marker {
  fill: rgba(51, 234, 255, 0.3);
  animation: hq-pulse 2s ease-in-out infinite;
}

.marker {
  fill: rgba(94, 179, 255, 0.3);
}

@keyframes hq-pulse {
  0%, 100% { r: 18; opacity: 0.5; }
  50% { r: 22; opacity: 0.8; }
}

.region-name {
  font-family: var(--font-display);
  font-size: 11px;
  fill: var(--text-primary);
  text-anchor: middle;
  font-weight: 600;
}

.connection-lines line {
  stroke: rgba(94, 179, 255, 0.3);
  stroke-width: 1;
  stroke-dasharray: 3,3;
}

.coverage-stats {
  display: flex;
  justify-content: center;
  gap: 3rem;
  margin-bottom: 2rem;
}

.coverage-stat {
  text-align: center;
}

.coverage-stat .stat-number {
  display: block;
  font-family: var(--font-display);
  font-size: 3rem;
  color: var(--accent);
  line-height: 1;
}

.coverage-stat .stat-label {
  font-size: 0.9rem;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.region-tag {

.region-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(94, 179, 255, 0.15);
  border: 1px solid var(--border);
  border-radius: 30px;
  padding: 0.5rem 1rem;
  font-size: 0.9rem;
  color: var(--text-secondary);
  font-family: var(--font-heading);
  font-weight: 600;
  transition: all var(--transition);
}

.region-tag:hover {
  background: var(--primary);
  color: white;
  transform: translateY(-2px);
  box-shadow: 0 5px 15px var(--glow);
}

.region-tag i {
  color: var(--accent);
  font-size: 0.8rem;
}

.region-tag:first-child i {
  color: var(--accent);
}

@media (max-width: 768px) {
  .about-story-grid { grid-template-columns: 1fr; gap: 2rem; }
}

.dale-profile-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2rem;
  text-align: center;
  width: 100%;
}

.dale-avatar {
  width: 180px;
  height: 180px;
  border-radius: 50%;
  background: var(--bg-card);
  margin: 0 auto 1.5rem;
  box-shadow: 0 15px 40px rgba(10,125,232,0.4);
  overflow: hidden;
  border: 4px solid rgba(10, 125, 232, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.dale-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
}

.dale-profile-card h3 {
  font-family: var(--font-display);
  font-size: 1.75rem;
  margin-bottom: 0.25rem;
}

.dale-title {
  color: var(--accent);
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.dale-since {
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
}

.dale-stats {
  display: flex;
  justify-content: center;
  gap: 2rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--border);
}

.dale-stat {
  text-align: center;
}

.dale-stat-num {
  display: block;
  font-family: var(--font-display);
  font-size: 2rem;
  color: var(--accent);
}

.dale-stat-label {
  font-size: 0.8rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
</style>
