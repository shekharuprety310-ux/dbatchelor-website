        <p style="color:var(--text-secondary);">Proudly Tasmanian, we support our local community and love helping celebrate milestones across our island home.</p>
      </div>
    </div>
  </div>
</section>

<!-- Coverage Map -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag"><i class="fas fa-map"></i> Our Coverage</span>
      <h2 class="section-title">We Come <span class="highlight">To You</span></h2>
      <p class="section-subtitle">Proudly servicing all regions of Tasmania</p>
    </div>
    
    <div class="tasmania-map-wrapper reveal-scale">
      <div class="tasmania-map">
        <svg viewBox="0 0 500 600" class="tasmania-svg">
          <!-- Background circle -->
          <circle cx="250" cy="300" r="280" fill="rgba(94, 179, 255, 0.05)" />
          
          <!-- Tasmania Island Shape -->
          <path class="tasmania-island" d="
            M 320,120 
            C 340,140 360,160 370,200
            C 380,240 375,280 360,320
            C 345,360 320,400 280,440
            C 240,480 180,500 120,480
            C 60,460 40,400 50,340
            C 60,280 100,220 150,160
            C 200,100 280,80 320,120
            Z
          " />
          
          <!-- Coastline details -->
          <path class="coastline" d="
            M 320,120 
            C 340,140 360,160 370,200
            C 380,240 375,280 360,320
            C 345,360 320,400 280,440
            C 240,480 180,500 120,480
            C 60,460 40,400 50,340
            C 60,280 100,220 150,160
            C 200,100 280,80 320,120
          " />
          
          <!-- Service Regions -->
          <g class="region-markers">
            <!-- Hobart Area - South East -->
            <circle cx="340" cy="260" r="18" class="hq-marker" />
            <circle cx="340" cy="260" r="10" fill="var(--accent)" />
            <text x="340" y="300" class="region-name">HOBART (HQ)</text>
            
            <!-- Launceston - North -->
            <circle cx="300" cy="120" r="12" class="marker" />
            <text x="300" y="100" class="region-name">LAUNCESTON</text>
            
            <!-- Devonport - North West -->
            <circle cx="220" cy="100" r="12" class="marker" />
            <text x="220" y="80" class="region-name">DEVONPORT</text>
            
            <!-- Burnie - North -->
            <circle cx="140" cy="90" r="12" class="marker" />
            <text x="140" y="70" class="region-name">BURNIE</text>
            
            <!-- Strahan - West -->
            <circle cx="100" cy="280" r="12" class="marker" />
            <text x="100" y="260" class="region-name">STRAHAN</text>
            
            <!-- Queenstown - West -->
            <circle cx="80" cy="340" r="12" class="marker" />
            <text x="80" y="320" class="region-name">QUEENSTOWN</text>
            
            <!-- St Helens - East -->
            <circle cx="360" cy="380" r="12" class="marker" />
            <text x="360" y="420" class="region-name">ST HELENS</text>
            
            <!-- Tasman Peninsula -->
            <circle cx="400" cy="230" r="12" class="marker" />
            <text x="400" y="210" class="region-name">TASMAN</text>
          </g>
          
          <!-- Connection lines from HQ -->
          <g class="connection-lines">
            <line x1="340" y1="260" x2="300" y2="120" class="connect-line" />
            <line x1="340" y1="260" x2="220" y2="100" class="connect-line" />
            <line x1="340" y1="260" x2="140" y2="90" class="connect-line" />
            <line x1="340" y1="260" x2="100" y2="280" class="connect-line" />
            <line x1="340" y1="260" x2="80" y2="340" class="connect-line" />
            <line x1="340" y1="260" x2="360" y2="380" class="connect-line" />
            <line x1="340" y1="260" x2="400" y2="230" class="connect-line" />
          </g>
        </svg>
      </div>
    </div>
    
    <div class="coverage-stats stagger mt-4">
      <div class="coverage-stat">
        <span class="stat-number">8+</span>
        <span class="stat-label">Regions Served</span>
      </div>
      <div class="coverage-stat">
        <span class="stat-number">500+</span>
        <span class="stat-label">Events Completed</span>
      </div>
      <div class="coverage-stat">
        <span class="stat-number">20+</span>
        <span class="stat-label">Years Experience</span>
      </div>
    </div>
    
    <div class="coverage-regions mt-4">
      <div class="region-tag"><i class="fas fa-star"></i> Hobart (HQ)</div>
      <div class="region-tag"><i class="fas fa-map-marker-alt"></i> Launceston</div>
      <div class="region-tag"><i class="fas fa-map-marker-alt"></i> Devonport</div>
      <div class="region-tag"><i class="fas fa-map-marker-alt"></i> Burnie</div>
      <div class="region-tag"><i class="fas fa-map-marker-alt"></i> Strahan</div>
      <div class="region-tag"><i class="fas fa-map-marker-alt"></i> Queenstown</div>
      <div class="region-tag"><i class="fas fa-map-marker-alt"></i> St Helens</div>
      <div class="region-tag"><i class="fas fa-map-marker-alt"></i> Tasman Peninsula</div>
    </div>
  </div>
</section>

<!-- CTA -->
