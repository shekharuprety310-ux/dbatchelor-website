<%- include('partials/header') %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content">
      <div class="breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>FAQ</span></div>
      <h1 class="text-gradient">Frequently Asked Questions</h1>
      <p style="color:var(--text-secondary); max-width:600px; margin: 1rem auto 0; font-size:1.1rem;">
        Everything you need to know before booking with us
      </p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container" style="max-width:860px;">

    <div class="faq-group reveal">
      <h3 class="faq-group-title"><i class="fas fa-music"></i> DJ & MC Services</h3>

      <div class="faq-item">
        <button class="faq-question">
          What types of events do you DJ?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>We DJ for all kinds of events including weddings, birthday parties, school formals, corporate functions, private parties, festivals, and more. No event is too big or too small!</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          Can I choose my own music playlist?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>Absolutely! We encourage clients to provide a preferred playlist at least 7–14 days prior to the event, along with any "must-play" and "do-not-play" songs. On-the-night requests are at DJ discretion.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          Do you provide MC services for weddings?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>Yes! We offer professional MC services to guide your event, announce key moments (grand entrance, first dance, speeches, cake cutting), and keep everything running on schedule. A run sheet is required at least 7 days prior.</p>
        </div>
      </div>
    </div>

    <div class="faq-group reveal">
      <h3 class="faq-group-title"><i class="fas fa-calendar-check"></i> Bookings & Payments</h3>

      <div class="faq-item">
        <button class="faq-question">
          How do I confirm my booking?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>Your booking is confirmed once a non-refundable deposit has been received. Contact us to discuss your event and we'll provide a quote. Payment can be made via bank transfer, PayID (0467 764 778), cash, or card.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          What is your cancellation policy?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>Deposits are non-refundable. Cancellation within a short period of the event may require full payment. If we cancel your booking, you will receive a full refund. Please contact us as early as possible if you need to reschedule.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          What payment methods do you accept?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>We accept bank transfer (BSB: 013711, Account: 179678283), PayID (0467 764 778), cash, and card payments. Card payments may incur a small fee.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          What are your overtime rates?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>Overtime is available subject to DJ availability and is charged at an agreed hourly rate. Please discuss overtime requirements when booking to ensure availability.</p>
        </div>
      </div>
    </div>

    <div class="faq-group reveal">
      <h3 class="faq-group-title"><i class="fas fa-tools"></i> Equipment & Setup</h3>

      <div class="faq-item">
        <button class="faq-question">
          What equipment do you supply?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>We supply professional PA speaker systems, subwoofers, wireless microphones, DJ controllers, mixing decks, dance floor lighting, smoke machines, and all cables and accessories. Setup and pack-down are included.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          What power requirements are needed?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>The client is responsible for providing access to standard 240V power at the venue. Please ensure power outlets are accessible near the DJ/setup area.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          Can you set up for outdoor events?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>Yes! We can set up for outdoor events. However, adequate shelter (tent, marquee, or cover) must be provided for all equipment. We are not liable for power failures or issues arising from weather conditions.</p>
        </div>
      </div>
    </div>

    <div class="faq-group reveal">
      <h3 class="faq-group-title"><i class="fas fa-map-marker-alt"></i> Coverage & Travel</h3>

      <div class="faq-item">
        <button class="faq-question">
          Where are you based and how far do you travel?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>We are based in Nubeena on the Tasman Peninsula, with our office in Hobart, Tasmania. We service all of Tasmania including Hobart, Launceston, Devonport, Burnie, Queenstown, St Helens, and everywhere in between.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          Are there travel fees?
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="faq-answer">
          <p>Travel fees may apply for events far from our base. This will be discussed when we prepare your quote. We always aim to be transparent about all costs upfront.</p>
        </div>
      </div>
    </div>

    <div class="faq-cta reveal">
      <h3>Still Have Questions?</h3>
      <p>We're happy to chat about your event and answer any questions you have.</p>
      <div class="flex-center gap-2 flex-wrap mt-3">
        <a href="/contact" class="btn btn-primary"><i class="fas fa-envelope"></i> Contact Us</a>
        <a href="tel:0467764778" class="btn btn-outline"><i class="fas fa-phone"></i> 0467 764 778</a>
      </div>
    </div>

  </div>
</section>

<%- include('partials/footer') %>

<style>
.faq-group { margin-bottom: 3rem; }

.faq-group-title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0.65rem;
}

.faq-item {
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-bottom: 0.75rem;
  overflow: hidden;
  transition: border-color var(--transition);
}

.faq-item.open { border-color: rgba(0,212,255,0.3); }

.faq-question {
  width: 100%;
  background: var(--bg-card);
  border: none;
  padding: 1.25rem 1.5rem;
  color: var(--text-primary);
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  text-align: left;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  transition: all var(--transition);
}

.faq-question:hover { color: var(--accent); }

.faq-question i {
  color: var(--primary);
  flex-shrink: 0;
  transition: transform var(--transition);
}

.faq-item.open .faq-question i { transform: rotate(180deg); }

.faq-answer {
  display: none;
  padding: 1.25rem 1.5rem;
  border-top: 1px solid var(--border);
  background: rgba(10,125,232,0.04);
}

.faq-answer.open { display: block; }

.faq-answer p {
  color: var(--text-secondary);
  line-height: 1.8;
}

.faq-cta {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 3rem;
  text-align: center;
  margin-top: 3rem;
}

.faq-cta h3 { font-size: 1.75rem; margin-bottom: 0.5rem; }
.faq-cta p { color: var(--text-secondary); }
</style>

<script>
document.querySelectorAll('.faq-question').forEach(btn => {
  btn.addEventListener('click', function() {
    const item = this.closest('.faq-item');
    const answer = item.querySelector('.faq-answer');
    const isOpen = item.classList.contains('open');

    // Close all
    document.querySelectorAll('.faq-item').forEach(i => {
      i.classList.remove('open');
      i.querySelector('.faq-answer').classList.remove('open');
    });

    if (!isOpen) {
      item.classList.add('open');
      answer.classList.add('open');
    }
  });
});
</script>
