<style>
.work-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}

.work-stat-item {
  text-align: center;
  padding: 1.5rem;
}

.portfolio-filters {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  justify-content: center;
}

.filter-btn {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 30px;
  padding: 0.5rem 1.25rem;
  color: var(--text-secondary);
  font-family: var(--font-heading);
  font-size: 0.875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: all var(--transition);
}

.filter-btn:hover, .filter-btn.active {
  background: var(--gradient-main);
  border-color: transparent;
  color: white;
  box-shadow: 0 4px 15px var(--glow);
}

.portfolio-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.portfolio-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all var(--transition);
}

.portfolio-card:hover {
  border-color: rgba(0,212,255,0.3);
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}

.portfolio-card-img {
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.wedding-img { background: linear-gradient(135deg, #2d1a4a, #4a1a6e); }
.birthday-img { background: linear-gradient(135deg, #1a3a4a, #0a4a8a); }
.corporate-img { background: linear-gradient(135deg, #0a2a3a, #0a4a5e); }
.party-img { background: linear-gradient(135deg, #1a2a0a, #0a4a2a); }
.wedding2-img { background: linear-gradient(135deg, #3a0a1a, #6a0a2e); }
.birthday2-img { background: linear-gradient(135deg, #3a2a0a, #6a4a0a); }

.event-emoji {
  font-size: 4rem;
  filter: drop-shadow(0 0 20px rgba(255,255,255,0.3));
}

.portfolio-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10,125,232,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity var(--transition);
  font-size: 1.5rem;
  color: white;
}

.portfolio-card:hover .portfolio-overlay { opacity: 1; }

.video-card-img {
  position: relative;
  cursor: pointer;
}

.video-card-img video {
  object-fit: cover;
}

.video-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60px;
  height: 60px;
  background: rgba(10,125,232,0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: white;
  z-index: 2;
  transition: all var(--transition);
}

.video-card-img:hover .video-play-btn {
  transform: translate(-50%, -50%) scale(1.1);
  background: var(--primary);
}

.video-duration {
  position: absolute;
  bottom: 10px;
  right: 10px;
  background: rgba(0,0,0,0.8);
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  font-size: 0.75rem;
  color: white;
  font-family: var(--font-heading);
}

.portfolio-card-info { padding: 1.25rem 1.5rem; }

.event-tag {
  display: inline-block;
  background: rgba(10,125,232,0.15);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 0.2rem 0.75rem;
  font-size: 0.75rem;
  font-family: var(--font-heading);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--accent);
  margin-bottom: 0.65rem;
  display: block;
  width: fit-content;
}

.portfolio-card-info h4 {
  font-family: var(--font-heading);
  font-size: 1rem;
  margin-bottom: 0.5rem;
}

.portfolio-card-info p {
  color: var(--text-muted);
  font-size: 0.875rem;
  line-height: 1.6;
}

/* Social CTA */
.social-cta-inner {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2.5rem;
  display: flex;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}

.social-cta-icon {
  width: 60px; height: 60px;
  border-radius: 16px;
  background: rgba(10,125,232,0.15);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.6rem;
  color: var(--primary);
  flex-shrink: 0;
}

.social-cta-inner h3 { font-size: 1.3rem; margin-bottom: 0.4rem; }
.social-cta-inner p { color: var(--text-secondary); font-size: 0.95rem; }
.social-cta-inner > div:nth-child(2) { flex: 1; }

.social-cta-buttons { display: flex; gap: 0.75rem; flex-wrap: wrap; flex-shrink: 0; }

@media (max-width: 768px) {
  .portfolio-grid { grid-template-columns: 1fr; }
  .work-stats { grid-template-columns: repeat(2,1fr); }
  .social-cta-inner { flex-direction: column; }
}
</style>

<script>
// Portfolio filter
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    const filter = this.dataset.filter;
    document.querySelectorAll('.portfolio-card').forEach(card => {
      if (filter === 'all' || card.dataset.category === filter) {
        card.style.display = '';
        card.style.opacity = '1';
      } else {
        card.style.display = 'none';
      }
    });
  });
});

// Video play functionality
document.querySelectorAll('.portfolio-video-card').forEach(card => {
  card.addEventListener('click', function() {
    const video = this.querySelector('video');
    if (video.paused) {
      video.play();
      this.querySelector('.video-play-btn').style.display = 'none';
    } else {
      video.pause();
      this.querySelector('.video-play-btn').style.display = 'flex';
    }
  });
});
</script>
