<!-- Hire terms -->
<section class="section" style="background:var(--bg-card); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
  <div class="container">
    <div class="grid-2" style="gap:3rem;">
      <div class="reveal-left">
        <span class="section-tag"><i class="fas fa-file-alt"></i> Hire Terms</span>
        <h2 class="section-title mt-2">Important <span class="highlight">Hire Information</span></h2>
        <div class="hire-terms-list">
          <div class="hire-term">
            <i class="fas fa-shield-alt"></i>
            <div>
              <strong>Equipment Responsibility</strong>
              <p>The client is responsible for all hired equipment during the hire period. Any loss, theft, or damage will be charged at full replacement cost.</p>
            </div>
          </div>
          <div class="hire-term">
            <i class="fas fa-plug"></i>
            <div>
              <strong>Power Requirements</strong>
              <p>Client must ensure safe access to 240V power supply and suitable space for equipment setup at the venue.</p>
            </div>
          </div>
          <div class="hire-term">
            <i class="fas fa-cloud-rain"></i>
            <div>
              <strong>Outdoor Events</strong>
              <p>Adequate shelter must be provided for all equipment at outdoor events. We're not liable for issues arising from weather conditions.</p>
            </div>
          </div>
          <div class="hire-term">
            <i class="fas fa-lock"></i>
            <div>
              <strong>Equipment Security</strong>
              <p>Equipment must not be moved or tampered with once set up without prior consent from D Batchelor Enterprises.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="reveal-right">
        <span class="section-tag"><i class="fas fa-phone-alt"></i> Contact for Payment</span>
        <h2 class="section-title mt-2">Get <span class="highlight">In Touch</span></h2>
        <div class="payment-options">
          <div class="payment-option highlight-option">
            <i class="fas fa-phone-alt"></i>
            <div>
              <strong>Call for Payment Details</strong>
              <span class="phone-large">0467 764 778</span>
            </div>
          </div>
          <div class="payment-option">
            <i class="fas fa-envelope"></i>
            <div>
              <strong>Email Us</strong>
              <span>dale@batchelorenterprises.com</span>
            </div>
          </div>
          <div class="payment-option">
            <i class="fas fa-money-bill-wave"></i>
            <div>
              <strong>Cash</strong>
              <span>Accepted on the day</span>
            </div>
          </div>
          <div class="payment-option">
            <i class="fas fa-credit-card"></i>
            <div>
              <strong>Card Payments</strong>
              <span>Available on request</span>
            </div>
          </div>
        </div>
        <div class="mt-4 p-note">
          <i class="fas fa-info-circle"></i>
          <p>A non-refundable deposit is required to confirm all hire bookings. Contact us for pricing and availability.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-sm">
  <div class="container text-center reveal" style="padding:4rem 2rem;">
    <h2 style="margin-bottom:1rem;">Get a Custom Equipment Quote</h2>
    <p style="color:var(--text-secondary); margin-bottom:2rem; max-width:500px; margin-left:auto; margin-right:auto;">
      Every event is different. Contact us to discuss your specific needs and we'll build a hire package that fits your budget.
    </p>
    <div class="flex-center gap-2 flex-wrap">
      <a href="/booking" class="btn btn-primary btn-lg"><i class="fas fa-calendar-plus"></i> Request a Quote</a>
      <a href="tel:0467764778" class="btn btn-outline btn-lg"><i class="fas fa-phone"></i> Call Now</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<style>
.equipment-showcase {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.equip-category {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all var(--transition);
}

.equip-category:hover { border-color: rgba(0,212,255,0.3); }

.ec-header {
  background: rgba(10,125,232,0.1);
  border-bottom: 1px solid var(--border);
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.85rem;
}

.ec-header i { color: var(--primary); font-size: 1.3rem; }
.ec-header h3 { font-family: var(--font-heading); font-size: 1rem; font-weight: 700; }

.ec-items { padding: 0.5rem 0; }

.ec-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: background var(--transition);
}

.ec-item:last-child { border-bottom: none; }
.ec-item:hover { background: rgba(10,125,232,0.05); }

.ec-name { color: var(--text-secondary); font-size: 0.9rem; }

.ec-status {
  font-size: 0.75rem;
  font-family: var(--font-heading);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.2rem 0.65rem;
  border-radius: 20px;
  font-weight: 600;
}

.ec-status.good { background: rgba(0,200,100,0.15); color: #00c864; border: 1px solid rgba(0,200,100,0.3); }
.ec-status.included { background: rgba(10,125,232,0.15); color: var(--accent); border: 1px solid var(--border); }
.ec-status.enquire { background: rgba(240,165,0,0.15); color: #f0a500; border: 1px solid rgba(240,165,0,0.3); }

.hire-terms-list { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1.5rem; }

.hire-term {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.hire-term i {
  width: 40px; height: 40px;
  border-radius: 10px;
  background: rgba(10,125,232,0.12);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: 1rem;
  flex-shrink: 0;
  margin-top: 0.1rem;
}

.hire-term strong { display: block; font-family: var(--font-heading); font-size: 0.95rem; margin-bottom: 0.25rem; }
.hire-term p { color: var(--text-secondary); font-size: 0.875rem; line-height: 1.7; }

.payment-options { display: flex; flex-direction: column; gap: 0.85rem; margin-top: 1.5rem; }

.payment-option {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: rgba(10,125,232,0.06);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem 1.25rem;
}

.payment-option.highlight-option {
  background: rgba(51, 234, 255, 0.15);
  border: 2px solid var(--accent);
}

.payment-option i { color: var(--primary); font-size: 1.3rem; width: 30px; text-align: center; }
.payment-option strong { display: block; font-family: var(--font-heading); font-size: 0.9rem; margin-bottom: 0.15rem; }
.payment-option span { color: var(--text-muted); font-size: 0.85rem; }

.phone-large {
  font-size: 1.4rem !important;
  color: var(--accent) !important;
  font-weight: 700 !important;
}

.p-note {
  display: flex;
  gap: 0.75rem;
  background: rgba(10,125,232,0.08);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem 1.25rem;
  align-items: flex-start;
}

.p-note i { color: var(--primary); margin-top: 0.15rem; flex-shrink: 0; }
.p-note p { color: var(--text-muted); font-size: 0.875rem; line-height: 1.7; }

@media (max-width: 768px) {
  .equipment-showcase { grid-template-columns: 1fr; }
}

.party-images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  height: 250px;
}

.party-img-card {
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  transition: all var(--transition);
}

.party-img-card:hover {
  transform: scale(1.02);
  box-shadow: var(--shadow);
}
</style>
