    <div class="section-header reveal">
      <span class="section-tag"><i class="fas fa-calendar-check"></i> Coming Up</span>
      <h2 class="section-title">Upcoming <span class="highlight">Events</span></h2>
    </div>

    <div class="upcoming-events-grid stagger">
      
      <div class="upcoming-event-card">
        <div class="ue-date-badge">
          <span class="ue-day">25</span>
          <span class="ue-month">APR</span>
        </div>
        <div class="ue-content">
          <h3>ANZAC Day Road Closures</h3>
          <p class="ue-location"><i class="fas fa-map-marker-alt"></i> Tasmania-wide</p>
          <p class="ue-type"><span class="badge-anzac">🕊️ Ceremony</span></p>
        </div>
        <div class="ue-emoji">
          <span>🕊️🎖️🇦🇺</span>
        </div>
      </div>

      <div class="upcoming-event-card">
        <div class="ue-date-badge">
          <span class="ue-day">18</span>
          <span class="ue-month">APR</span>
        </div>
        <div class="ue-content">
          <h3>80th Birthday Celebration</h3>
          <p class="ue-location"><i class="fas fa-map-marker-alt"></i> Tasmania</p>
          <p class="ue-type"><span class="badge-birthday">🎂 Milestone Birthday</span></p>
        </div>
        <div class="ue-emoji">
          <span>🎂👴👑</span>
        </div>
      </div>

      <div class="upcoming-event-card ue-highlight">
        <div class="ue-date-badge">
          <span class="ue-day">01</span>
          <span class="ue-month">MAY</span>
        </div>
        <div class="ue-content">
          <h3>Agfest 2026</h3>
          <p class="ue-location"><i class="fas fa-map-marker-alt"></i> 789 AgFest Days</p>
          <p class="ue-type"><span class="badge-agfest">🌾 Festival</span></p>
          <p class="ue-dates">1st May - 20th May</p>
        </div>
        <div class="ue-emoji">
          <span>🌾🚜🐄</span>
        </div>
      </div>

      <div class="upcoming-event-card">
        <div class="ue-date-badge">
          <span class="ue-day">20</span>
          <span class="ue-month">JUN</span>
        </div>
        <div class="ue-content">
          <h3>Engagement Party</h3>
          <p class="ue-location"><i class="fas fa-map-marker-alt"></i> Queenstown</p>
          <p class="ue-type"><span class="badge-wedding">💍 Wedding</span></p>
        </div>
        <div class="ue-emoji">
          <span>💍💕🥂</span>
        </div>
      </div>

      <div class="upcoming-event-card">
        <div class="ue-date-badge">
          <span class="ue-day">27</span>
          <span class="ue-month">JUN</span>
        </div>
        <div class="ue-content">
          <h3>18th Birthday Party</h3>
          <p class="ue-location"><i class="fas fa-map-marker-alt"></i> East Coasters</p>
          <p class="ue-type"><span class="badge-birthday">🎉 Birthday</span></p>
        </div>
        <div class="ue-emoji">
          <span>🎉🎊🎁</span>
        </div>
      </div>

    </div>

    <div class="text-center mt-4">
      <a href="/booking" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add Your Event
      </a>
    </div>
  </div>
</section>

<!-- Availability Calendar Section -->
<section id="availability-calendar" class="section" style="background: var(--bg-dark);">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag"><i class="fas fa-calendar-alt"></i> Check Availability</span>
      <h2 class="section-title">Book Your <span class="highlight">Date</span></h2>
      <p class="section-subtitle">Click on available dates to check availability or book directly</p>
    </div>

    <div class="calendar-wrapper">
      <div class="calendar-header">
        <button class="cal-nav-btn" id="prevMonth"><i class="fas fa-chevron-left"></i></button>
        <h3 id="currentMonth">April 2026</h3>
        <button class="cal-nav-btn" id="nextMonth"><i class="fas fa-chevron-right"></i></button>
      </div>

      <div class="calendar-weekdays">
        <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
      </div>

      <div class="calendar-days" id="calendarDays">
        <!-- Generated by JavaScript -->
      </div>

      <div class="calendar-legend">
        <div class="legend-item"><span class="legend-dot available"></span> Available</div>
        <div class="legend-item"><span class="legend-dot booked"></span> Event Booked</div>
        <div class="legend-item"><span class="legend-dot limited"></span> Limited</div>
      </div>
    </div>

    <div class="calendar-cta">
      <p>Can't find your date? <a href="/contact">Contact us</a> to check availability</p>
      <a href="/booking" class="btn btn-primary mt-3">
        <i class="fas fa-calendar-check"></i> Book Now
      </a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-sm">
  <div class="container text-center reveal" style="padding: 4rem 2rem;">
    <div class="equalizer" style="justify-content:center; margin-bottom:1.5rem;">
      <div class="bar"></div><div class="bar"></div><div class="bar"></div>
      <div class="bar"></div><div class="bar"></div><div class="bar"></div>
    </div>
    <h2 style="margin-bottom:1rem;">Your Event Could Be Next</h2>
    <p style="color:var(--text-secondary); margin-bottom:2rem; max-width:500px; margin-left:auto; margin-right:auto;">
      Get in touch today and let's start planning something unforgettable.
    </p>
    <a href="/booking" class="btn btn-primary btn-lg btn-pulse">
      <i class="fas fa-calendar-plus"></i> Book Your Event
    </a>
  </div>
</section>

<%- include('partials/footer') %>

<style>
/* Events Tab Navigation */
.events-tabs {
  position: fixed;
  top: 70px;
  left: 0;
  right: 0;
  background: rgba(8, 14, 26, 0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  z-index: 999;
  padding: 0.75rem 0;
}

.tabs-nav {
  display: flex;
  justify-content: center;
  gap: 1rem;
  max-width: 600px;
  margin: 0 auto;
}

.tab-btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 30px;
  color: var(--text-secondary);
  font-weight: 600;
  font-size: 0.9rem;
  transition: all var(--transition);
}

.tab-btn:hover {
  color: var(--primary);
  border-color: var(--primary);
}

.tab-btn.active {
  background: var(--primary);
  border-color: var(--primary);
  color: white;
}

.tab-btn i {
  font-size: 1rem;
}

/* Page hero adjustment for fixed tabs */
.page-hero {
  padding-top: 120px;
}

/* Section sub header */
.section-sub-header {
  text-align: center;
  margin-bottom: 2rem;
}

.section-sub-header h3 {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  color: var(--text-secondary);
  font-weight: 500;
}

/* Past Events Section - keep showing by default */
#past-events {
  padding-top: 2rem;
}

/* Hide upcoming by default until scrolled */
#upcoming-events {
  display: none;
  padding-top: 2rem;
}

#upcoming-events.show {
  display: block;
}

.upcoming-events-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-top: 2rem;
}

.upcoming-event-card {
  background: var(--bg-dark);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  transition: all var(--transition);
  position: relative;
}

.upcoming-event-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--primary);
}

.upcoming-event-card.ue-highlight {
  border-color: var(--accent);
  background: linear-gradient(135deg, var(--bg-dark) 0%, rgba(51, 234, 255, 0.1) 100%);
}

.ue-date-badge {
  background: var(--primary);
  border-radius: 10px;
  padding: 0.75rem 0.5rem;
  text-align: center;
  min-width: 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ue-day {
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
  line-height: 1;
}

.ue-month {
  font-size: 0.7rem;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  letter-spacing: 0.1em;
  margin-top: 2px;
}

.ue-content {
  padding: 0.5rem 0;
}

.ue-content h3 {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  line-height: 1.3;
}

.ue-location {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.ue-location i {
  color: var(--primary);
  margin-right: 5px;
}

.ue-type {
  font-size: 0.8rem;
}

.ue-type .badge-anzac,
.ue-type .badge-birthday,
.ue-type .badge-agfest,
.ue-type .badge-wedding {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.badge-anzac { background: rgba(255, 200, 51, 0.2); color: #ffc933; }
.badge-birthday { background: rgba(255, 107, 107, 0.2); color: #ff6b6b; }
.badge-agfest { background: rgba(94, 179, 255, 0.2); color: #5eb3ff; }
.badge-wedding { background: rgba(255, 105, 180, 0.2); color: #ff69b4; }

.ue-dates {
  font-size: 0.8rem;
  color: var(--accent);
  margin-top: 0.5rem;
  font-weight: 600;
}

.ue-emoji {
  font-size: 1.8rem;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 60px;
  gap: 2px;
}

.ue-emoji span {
  display: flex;
  gap: 2px;
}

@media (max-width: 768px) {
  .events-tabs {
    top: 60px;
  }
  
  .tabs-nav {
    gap: 0.5rem;
    padding: 0 0.5rem;
  }
  
  .tab-btn {
    padding: 0.6rem 1rem;
    font-size: 0.8rem;
  }
  
  .page-hero {
    padding-top: 110px;
  }
  
  .upcoming-event-card {
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
  }
  
  .ue-emoji {
    grid-column: 1 / -1;
    font-size: 2rem;
    justify-content: flex-start;
    margin-top: 0.5rem;
  }
  
  .ue-date-badge {
    min-width: 50px;
    padding: 0.5rem;
  }
  
  .ue-day {
    font-size: 1.2rem;
  }
}

.event-showcase {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.event-showcase-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all var(--transition);
}

.event-showcase-card:hover {
  border-color: rgba(0,212,255,0.3);
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.esc-header {
  padding: 2.5rem 2rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
}

.wedding-header { background: linear-gradient(135deg, rgba(45,26,74,0.8), rgba(74,26,110,0.5)); }
.birthday-header { background: linear-gradient(135deg, rgba(26,58,74,0.8), rgba(10,74,138,0.5)); }
.corporate-header { background: linear-gradient(135deg, rgba(10,42,58,0.8), rgba(10,74,94,0.5)); }
.formal-header { background: linear-gradient(135deg, rgba(26,42,10,0.8), rgba(10,74,42,0.5)); }

.esc-emoji { font-size: 2.5rem; }

.esc-header h3 {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  font-weight: 700;
}

.esc-body {
  padding: 1.5rem 2rem 2rem;
}

.esc-body p {
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 1.25rem;
}

.esc-features {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
}

.esc-features li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-secondary);
  font-size: 0.9rem;
}

.esc-features i { color: var(--primary); font-size: 0.8rem; }

/* Gallery grid */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: 200px 200px;
  gap: 1rem;
  margin-bottom: 2rem;
}

.gallery-item {
  border-radius: var(--radius);
  overflow: hidden;
  position: relative;
  cursor: pointer;
  transition: all var(--transition);
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-item::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(10, 125, 232, 0.3);
  opacity: 0;
  transition: opacity var(--transition);
}

.gallery-item:hover::after { opacity: 1; }

.gallery-item img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.gallery-item:hover { transform: scale(1.02); box-shadow: var(--shadow-lg); }

.gi-large { grid-row: 1 / 3; }
.gi-wide { grid-column: 2 / 4; }

.wedding-gallery { background: linear-gradient(135deg, #2d1a4a, #6a2a9e); }
.birthday-gallery { background: linear-gradient(135deg, #1a3a6a, #0a5aaa); }
.party-gallery { background: linear-gradient(135deg, #3a1a4a, #8a2a6a); }
.corporate-gallery { background: linear-gradient(135deg, #0a2a3a, #0a5a7a); }
.outdoor-gallery { background: linear-gradient(135deg, #1a3a1a, #0a6a3a); }

.gallery-content {
  text-align: center;
  position: relative;
  z-index: 1;
}

.gallery-content span { font-size: 3rem; display: block; margin-bottom: 0.5rem; }
.gallery-content p {
  color: rgba(255,255,255,0.9);
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.gallery-social-cta {
  background: rgba(10,125,232,0.08);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2rem;
  text-align: center;
}

.gallery-social-cta p { color: var(--text-secondary); font-size: 1rem; }

@media (max-width: 768px) {
  .event-showcase { grid-template-columns: 1fr; }
  .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
  .gi-large, .gi-wide { grid-row: auto; grid-column: auto; }
  .esc-features { grid-template-columns: 1fr; }
}
</style>

<!-- Calendar CSS -->
<style>
.calendar-wrapper {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2rem;
  max-width: 600px;
  margin: 0 auto;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.calendar-header h3 {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  color: var(--text-primary);
}

.cal-nav-btn {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.5rem 1rem;
  color: var(--text-primary);
  cursor: pointer;
  transition: all var(--transition);
}

.cal-nav-btn:hover {
  background: var(--primary);
  border-color: var(--primary);
  color: white;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 5px;
  margin-bottom: 1rem;
}

.calendar-weekdays span {
  text-align: center;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text-muted);
  padding: 0.5rem;
  text-transform: uppercase;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8px;
}

.cal-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all var(--transition);
  border: 1px solid transparent;
  position: relative;
}

.cal-day:hover:not(.empty):not(.other-month) {
  border-color: var(--primary);
  transform: scale(1.05);
}

.cal-day.empty {
  background: transparent;
  cursor: default;
}

.cal-day.other-month {
  color: var(--text-muted);
  opacity: 0.4;
  cursor: default;
}

.cal-day.available {
  background: rgba(94, 179, 255, 0.15);
  border-color: rgba(94, 179, 255, 0.3);
  color: var(--primary);
}

.cal-day.available:hover {
  background: var(--primary);
  color: white;
}

.cal-day.booked {
  background: rgba(94, 179, 255, 0.15);
  border-color: rgba(94, 179, 255, 0.4);
  color: var(--primary);
  cursor: pointer;
  flex-direction: column;
  padding: 4px;
  gap: 2px;
}

.cal-day.booked:hover {
  background: rgba(94, 179, 255, 0.3);
  transform: scale(1.05);
}

.cal-event-emoji {
  font-size: 1.2rem;
  line-height: 1;
}

.cal-event-name {
  font-size: 0.55rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.cal-day.limited {
  background: rgba(255, 200, 51, 0.15);
  border-color: rgba(255, 200, 51, 0.3);
  color: #ffc933;
}

.cal-day.today {
  border: 2px solid var(--accent);
  font-weight: 700;
}

.cal-day.has-event::before {
  content: '';
  position: absolute;
  bottom: 4px;
  width: 6px;
  height: 6px;
  background: var(--accent);
  border-radius: 50%;
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 2rem;
  margin-top: 1.5rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.legend-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}

.legend-dot.available { background: var(--primary); }
.legend-dot.booked { background: var(--primary); opacity: 0.7; }
.legend-dot.limited { background: #ffc933; }

.calendar-cta {
  text-align: center;
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
}

.calendar-cta p {
  color: var(--text-secondary);
}

.calendar-cta a {
  color: var(--primary);
  font-weight: 600;
}

.calendar-cta a:hover {
  color: var(--accent);
}

@media (max-width: 768px) {
  .calendar-wrapper {
    padding: 1rem;
  }
  
  .calendar-header h3 {
    font-size: 1.2rem;
  }
  
  .cal-day {
    font-size: 0.85rem;
  }
  
  .calendar-legend {
    flex-wrap: wrap;
    gap: 1rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const tabBtns = document.querySelectorAll('.tab-btn');
  const pastEvents = document.getElementById('past-events');
  const upcomingEvents = document.getElementById('upcoming-events');
  
  // Handle tab click
  tabBtns.forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      
      // Update active tab
      tabBtns.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      
      // Show/hide sections based on which tab clicked
      const target = this.getAttribute('href');
      
      if (target === '#upcoming-events') {
        pastEvents.style.display = 'none';
        upcomingEvents.classList.add('show');
        upcomingEvents.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        upcomingEvents.classList.remove('show');
        pastEvents.style.display = 'block';
        pastEvents.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
  
  // Optional: Auto-show upcoming when scrolling down past gallery
  window.addEventListener('scroll', function() {
    const gallery = document.getElementById('gallery');
    const upcomingTab = document.querySelector('.tab-btn[href="#upcoming-events"]');
    
    if (gallery) {
      const galleryBottom = gallery.offsetTop + gallery.offsetHeight;
      const scrollPos = window.scrollY + window.innerHeight;
      
      if (scrollPos > galleryBottom + 100) {
        // Automatically click the upcoming tab
        if (!upcomingTab.classList.contains('active')) {
          upcomingTab.click();
        }
      }
    }
  });
  
  // ============ Calendar Functionality ============
  const calendarDays = document.getElementById('calendarDays');
  const currentMonthEl = document.getElementById('currentMonth');
  const prevMonthBtn = document.getElementById('prevMonth');
  const nextMonthBtn = document.getElementById('nextMonth');
  
  // Booked dates with event names
  const bookedDates = {
    '2026-04-18': { name: '80th Birthday', emoji: '🎂' },
    '2026-04-25': { name: 'ANZAC Day', emoji: '🕊️' },
    '2026-05-01': { name: 'Agfest Start', emoji: '🌾' },
    '2026-05-02': { name: 'Agfest', emoji: '🚜' },
    '2026-05-03': { name: 'Agfest', emoji: '🐄' },
    '2026-05-04': { name: 'Agfest', emoji: '🌾' },
    '2026-05-05': { name: 'Agfest', emoji: '🚜' },
    '2026-05-06': { name: 'Agfest', emoji: '🐄' },
    '2026-05-07': { name: 'Agfest', emoji: '🌾' },
    '2026-05-08': { name: 'Agfest', emoji: '🚜' },
    '2026-05-09': { name: 'Agfest', emoji: '🐄' },
    '2026-05-10': { name: 'Agfest', emoji: '🌾' },
    '2026-05-11': { name: 'Agfest', emoji: '🚜' },
    '2026-05-12': { name: 'Agfest', emoji: '🐄' },
    '2026-05-13': { name: 'Agfest', emoji: '🌾' },
    '2026-05-14': { name: 'Agfest', emoji: '🚜' },
    '2026-05-15': { name: 'Agfest', emoji: '🐄' },
    '2026-05-16': { name: 'Agfest', emoji: '🌾' },
    '2026-05-17': { name: 'Agfest', emoji: '🚜' },
    '2026-05-18': { name: 'Agfest', emoji: '🐄' },
    '2026-05-19': { name: 'Agfest', emoji: '🌾' },
    '2026-05-20': { name: 'Agfest End', emoji: '🎉' },
    '2026-06-20': { name: 'Engagement', emoji: '💍' },
    '2026-06-27': { name: '18th Birthday', emoji: '🎉' }
  };
  
  // Limited availability dates
  const limitedDates = [
    '2026-04-10', '2026-04-11', '2026-04-12',
    '2026-05-25', '2026-05-30',
    '2026-06-05', '2026-06-15', '2026-06-25'
  ];
  
  let currentDate = new Date();
  let currentYear = currentDate.getFullYear();
  let currentMonth = currentDate.getMonth();
  
  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 
                      'July', 'August', 'September', 'October', 'November', 'December'];
  
  function renderCalendar(year, month) {
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const daysInPrevMonth = new Date(year, month, 0).getDate();
    const today = new Date();
    
    currentMonthEl.textContent = `${monthNames[month]} ${year}`;
    calendarDays.innerHTML = '';
    
    // Previous month days
    for (let i = firstDay - 1; i >= 0; i--) {
      const day = document.createElement('div');
      day.className = 'cal-day other-month';
      day.textContent = daysInPrevMonth - i;
      calendarDays.appendChild(day);
    }
    
    // Current month days
    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const dayEl = document.createElement('div');
      dayEl.className = 'cal-day';
      
      // Check if it's today
      if (year === today.getFullYear() && month === today.getMonth() && day === today.getDate()) {
        dayEl.classList.add('today');
      }
      
      // Check if has booked event
      if (bookedDates[dateStr]) {
        const event = bookedDates[dateStr];
        dayEl.classList.add('booked');
        dayEl.innerHTML = `<span class="cal-event-emoji">${event.emoji}</span><span class="cal-event-name">${event.name}</span>`;
        dayEl.title = event.name;
      } else if (limitedDates.includes(dateStr)) {
        dayEl.classList.add('limited');
        dayEl.textContent = day;
        dayEl.title = 'Limited Availability';
      } else {
        dayEl.classList.add('available');
        dayEl.textContent = day;
        dayEl.title = 'Available - Click to Book';
        dayEl.addEventListener('click', () => {
          window.location.href = '/booking?date=' + dateStr;
        });
      }
      
      calendarDays.appendChild(dayEl);
    }
    
    // Next month days to fill grid
    const totalCells = firstDay + daysInMonth;
    const remainingCells = totalCells > 35 ? 42 - totalCells : 35 - totalCells;
    
    for (let i = 1; i <= remainingCells; i++) {
      const day = document.createElement('div');
      day.className = 'cal-day other-month';
      day.textContent = i;
      calendarDays.appendChild(day);
    }
  }
  
  prevMonthBtn.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 0) {
      currentMonth = 11;
      currentYear--;
    }
    renderCalendar(currentYear, currentMonth);
  });
  
  nextMonthBtn.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 11) {
      currentMonth = 0;
      currentYear++;
    }
    renderCalendar(currentYear, currentMonth);
  });
  
  // Initial render
  renderCalendar(currentYear, currentMonth);
});
</script>
