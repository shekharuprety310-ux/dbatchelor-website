<%- include('partials/header') %>

<!-- Events Tab Navigation -->
<div class="events-tabs">
  <div class="container">
    <div class="tabs-nav">
      <a href="#past-events" class="tab-btn active">
        <i class="fas fa-history"></i> Past Events
      </a>
      <a href="#upcoming-events" class="tab-btn">
        <i class="fas fa-calendar-check"></i> Upcoming Events
      </a>
    </div>
  </div>
</div>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content">
      <div class="breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Events</span></div>
      <h1 class="text-gradient">Events & Gallery</h1>
      <p style="color:var(--text-secondary); max-width:600px; margin: 1rem auto 0; font-size:1.1rem;">
        Celebrating every milestone across Tasmania
      </p>
    </div>
  </div>
</section>

<!-- Past Events Section -->
<section id="past-events" class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag"><i class="fas fa-history"></i> Our History</span>
      <h2 class="section-title">Past <span class="highlight">Events</span></h2>
    </div>

    <!-- Event Types Showcase -->
    <div class="section-sub-header">
      <h3>Event Types We Specialise In</h3>
    </div>

    <div class="event-showcase stagger">

      <div class="event-showcase-card">
        <div class="esc-header wedding-header">
          <div class="esc-emoji">💍</div>
          <h3>Weddings</h3>
        </div>
        <div class="esc-body">
          <p>Your wedding day is the most important day of your life. We provide seamless DJ, MC and audio services to make every moment perfect — from the ceremony walk-in to the last dance.</p>
          <ul class="esc-features">
            <li><i class="fas fa-check"></i> Ceremony music & PA</li>
            <li><i class="fas fa-check"></i> Cocktail hour background music</li>
            <li><i class="fas fa-check"></i> Reception DJ & MC</li>
            <li><i class="fas fa-check"></i> First dance coordination</li>
            <li><i class="fas fa-check"></i> Speeches & formalities</li>
            <li><i class="fas fa-check"></i> Dance floor lighting</li>
          </ul>
          <a href="/booking" class="btn btn-primary mt-3">Enquire for Weddings</a>
        </div>
      </div>

      <div class="event-showcase-card">
        <div class="esc-header birthday-header">
          <div class="esc-emoji">🎂</div>
          <h3>Birthdays & Milestones</h3>
        </div>
        <div class="esc-body">
          <p>Whether it's an 18th, 21st, 40th, or 60th — we make milestone birthdays unforgettable. Custom music, lighting effects, and energy that gets the whole crowd moving.</p>
          <ul class="esc-features">
            <li><i class="fas fa-check"></i> DJ with custom playlist</li>
            <li><i class="fas fa-check"></i> Party lighting package</li>
            <li><i class="fas fa-check"></i> Smoke & effects machines</li>
            <li><i class="fas fa-check"></i> Wireless microphone for speeches</li>
            <li><i class="fas fa-check"></i> Equipment hire options</li>
            <li><i class="fas fa-check"></i> Indoor & outdoor setups</li>
          </ul>
          <a href="/booking" class="btn btn-primary mt-3">Enquire for Birthdays</a>
        </div>
      </div>

      <div class="event-showcase-card">
        <div class="esc-header corporate-header">
          <div class="esc-emoji">🏢</div>
          <h3>Corporate Events</h3>
        </div>
        <div class="esc-body">
          <p>Professional entertainment and audio solutions for corporate functions, end-of-year parties, award nights, conferences, and product launches. Polished, reliable, and on-brand.</p>
          <ul class="esc-features">
            <li><i class="fas fa-check"></i> Professional PA systems</li>
            <li><i class="fas fa-check"></i> Background & event music</li>
            <li><i class="fas fa-check"></i> MC & announcements</li>
            <li><i class="fas fa-check"></i> Award night audio</li>
            <li><i class="fas fa-check"></i> Conference sound support</li>
            <li><i class="fas fa-check"></i> Fully insured & ABN registered</li>
          </ul>
          <a href="/booking" class="btn btn-primary mt-3">Enquire for Corporate</a>
        </div>
      </div>

      <div class="event-showcase-card">
        <div class="esc-header formal-header">
          <div class="esc-emoji">🎓</div>
          <h3>School Formals & Balls</h3>
        </div>
        <div class="esc-body">
          <p>Make it a night your students will never forget. Professional DJ with the hottest current tracks, energetic MC, and impressive lighting shows that create an incredible atmosphere.</p>
          <ul class="esc-features">
            <li><i class="fas fa-check"></i> Current chart music</li>
            <li><i class="fas fa-check"></i> Energetic MC host</li>
            <li><i class="fas fa-check"></i> Full lighting production</li>
            <li><i class="fas fa-check"></i> Request management</li>
            <li><i class="fas fa-check"></i> Crowd-read expertise</li>
            <li><i class="fas fa-check"></i> Safe & professional service</li>
          </ul>
          <a href="/booking" class="btn btn-primary mt-3">Enquire for Formals</a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Photo/Video Gallery placeholder -->
<section class="section" style="background: var(--bg-card); border-top:1px solid var(--border); border-bottom:1px solid var(--border);" id="gallery">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag"><i class="fas fa-photo-video"></i> Gallery</span>
      <h2 class="section-title">Moments We've <span class="highlight">Created</span></h2>
      <p class="section-subtitle">Follow us on social media for live event coverage and videos</p>
    </div>

    <div class="gallery-grid stagger">
      <div class="gallery-item gi-large">
        <img src="/media/events/IMG_0732.JPEG" alt="Wedding" style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-content"><span>💍</span><p>Wedding Receptions</p></div>
      </div>
      <div class="gallery-item">
        <img src="/media/events/IMG_1662.JPEG" alt="Birthday" style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-content"><span>🎂</span><p>Birthday Bashes</p></div>
      </div>
      <div class="gallery-item">
        <img src="/media/events/IMG_1663.JPEG" alt="Corporate" style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-content"><span>🏢</span><p>Corporate Nights</p></div>
      </div>
      <div class="gallery-item gi-wide">
        <img src="/media/events/IMG_0848.JPEG" alt="Party" style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-content"><span>🎉</span><p>Private Parties & Events</p></div>
      </div>
      <div class="gallery-item">
        <img src="/media/events/IMG_1307.JPEG" alt="Formal" style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-content"><span>🎓</span><p>Formals & Balls</p></div>
      </div>
    </div>

    <div class="gallery-social-cta reveal">
      <p>📸 <strong>See real photos and videos</strong> from our events on our social media pages</p>
      <div class="flex-center gap-2 mt-3 flex-wrap">
        <a href="https://www.facebook.com/Batchelorenterprisestasptyltd/" target="_blank" class="btn btn-primary">
          <i class="fab fa-facebook-f"></i> View on Facebook
        </a>
        <a href="https://www.instagram.com/dbatchelorenterprises/" target="_blank" class="btn btn-outline">
          <i class="fab fa-instagram"></i> View on Instagram
        </a>
        <a href="https://www.tiktok.com/@dbatchelorenterprises" target="_blank" class="btn btn-outline">
          <i class="fab fa-tiktok"></i> View on TikTok
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Upcoming Events Section -->
