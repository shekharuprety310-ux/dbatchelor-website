<%- include('partials/header') %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content">
      <div class="breadcrumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/services">Services</a><span class="sep">/</span>
        <span>Mobile DJ Hire</span>
      </div>
      <h1 class="text-gradient">Mobile DJ Hire</h1>
      <p style="color:var(--text-secondary); max-width:600px; margin: 1rem auto 0; font-size:1.1rem;">
        Professional DJ & MC services for any event across Tasmania
      </p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="dj-intro-grid">
      <div class="reveal-left">
        <span class="section-tag"><i class="fas fa-compact-disc"></i> DJ Services</span>
        <h2 class="section-title mt-2">Your Music, <span class="highlight">Your Way</span></h2>
        <p style="color:var(--text-secondary); line-height:1.9; margin:1rem 0;">
          Our experienced DJ brings premium equipment, an extensive music library, and the skill to read 
          any crowd. Whether you want classic hits, current chart toppers, or a specific genre — we'll 
          deliver the soundtrack to your perfect event.
        </p>
        <p style="color:var(--text-secondary); line-height:1.9; margin-bottom:1.5rem;">
          We work closely with you before your event to understand your music preferences, create a custom 
          playlist, and ensure every song is perfectly timed to the key moments of your event.
        </p>

        <div class="dj-features-grid">
          <div class="dj-feature">
            <i class="fas fa-music"></i>
            <div>
              <strong>Custom Playlists</strong>
              <span>Your music preferences, curated perfectly</span>
            </div>
          </div>
          <div class="dj-feature">
            <i class="fas fa-volume-up"></i>
            <div>
              <strong>Premium Equipment</strong>
              <span>Professional PA, subs & DJ gear</span>
            </div>
          </div>
          <div class="dj-feature">
            <i class="fas fa-lightbulb"></i>
            <div>
              <strong>Lighting Included</strong>
              <span>Dance floor lighting with DJ packages</span>
            </div>
          </div>
          <div class="dj-feature">
            <i class="fas fa-truck"></i>
            <div>
              <strong>Setup & Pack-down</strong>
              <span>We handle all setup and pack-down</span>
            </div>
          </div>
        </div>
      </div>

      <div class="dj-visual reveal-right">
        <div class="dj-logo-box">
          <img src="/media/events/IMG_0732.JPEG" alt="Wedding DJ Services" style="width:100%; height:280px; object-fit:cover; border-radius:12px;">
        </div>
        <div class="dj-logo-box mt-3">
          <img src="/media/events/IMG_0848.JPEG" alt="Wedding Reception DJ" style="width:100%; height:180px; object-fit:cover; border-radius:12px;">
        </div>
        <div class="dj-contact-prompt mt-3">
          <i class="fas fa-phone-alt"></i>
          <div>
            <strong>Ready to Book?</strong>
            <a href="tel:0467764778">0467 764 778</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- What's included -->
<section class="section" style="background:var(--bg-card); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag"><i class="fas fa-list-check"></i> What's Included</span>
      <h2 class="section-title">Our DJ <span class="highlight">Package Includes</span></h2>
    </div>
    <div class="grid-3 stagger">
      <div class="included-card">
        <i class="fas fa-compact-disc"></i>
        <h4>Professional DJ Services</h4>
        <p>Experienced DJ who reads the crowd and keeps the energy high throughout your event.</p>
      </div>
      <div class="included-card">
        <i class="fas fa-microphone-alt"></i>
        <h4>MC Services (Optional)</h4>
        <p>Master of Ceremonies to guide your event, make announcements, and handle formalities.</p>
      </div>
      <div class="included-card">
        <i class="fas fa-speaker"></i>
        <h4>Sound System</h4>
        <p>Professional PA speakers, subwoofers, and amplifiers sized for your venue.</p>
      </div>
      <div class="included-card">
        <i class="fas fa-lightbulb"></i>
        <h4>Lighting Setup</h4>
        <p>Dance floor lighting effects to create the perfect atmosphere (included where specified).</p>
      </div>
      <div class="included-card">
        <i class="fas fa-music"></i>
        <h4>Music Tailoring</h4>
        <p>Pre-event consultation to build your playlist from your preferred genres and songs.</p>
      </div>
      <div class="included-card">
        <i class="fas fa-tools"></i>
        <h4>Full Setup & Pack-Down</h4>
        <p>We arrive early to set up, and stay until all equipment is packed down after your event.</p>
      </div>
    </div>
  </div>
</section>

<!-- Wedding specific -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag">💍 Weddings</span>
      <h2 class="section-title">Wedding DJ <span class="highlight">Specialists</span></h2>
      <p class="section-subtitle">We understand how important your wedding music is. Here's how we make it perfect.</p>
    </div>

    <div class="wedding-timeline stagger">
      <div class="wt-item">
        <div class="wt-icon"><i class="fas fa-ring"></i></div>
        <div class="wt-content">
          <h4>Ceremony</h4>
          <p>Walk-in music, signing, and recessional. PA system for outdoor or venue ceremonies.</p>
        </div>
      </div>
      <div class="wt-item">
        <div class="wt-icon"><i class="fas fa-glass-cheers"></i></div>
        <div class="wt-content">
          <h4>Cocktail Hour</h4>
          <p>Elegant background music while guests mingle and enjoy pre-dinner drinks.</p>
        </div>
      </div>
      <div class="wt-item">
        <div class="wt-icon"><i class="fas fa-door-open"></i></div>
        <div class="wt-content">
          <h4>Grand Entrance</h4>
          <p>Perfectly timed music for the wedding party and couple's grand entrance into reception.</p>
        </div>
      </div>
      <div class="wt-item">
        <div class="wt-icon"><i class="fas fa-heart"></i></div>
        <div class="wt-content">
          <h4>First Dance</h4>
          <p>Your special song, perfectly cued and presented by our MC for this unforgettable moment.</p>
        </div>
      </div>
      <div class="wt-item">
        <div class="wt-icon"><i class="fas fa-microphone"></i></div>
        <div class="wt-content">
          <h4>Speeches & Formalities</h4>
          <p>MC coordination of speeches, cake cutting, bouquet toss, and other formalities.</p>
        </div>
      </div>
      <div class="wt-item">
        <div class="wt-icon"><i class="fas fa-compact-disc"></i></div>
        <div class="wt-content">
          <h4>Reception Party</h4>
          <p>Full DJ set keeping your dance floor packed all night long until the last song.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pre-event form info -->
<section class="section" style="background:var(--bg-card); border-top:1px solid var(--border);">
  <div class="container">
    <div class="grid-2" style="gap:3rem; align-items:center;">
      <div class="reveal-left">
        <span class="section-tag"><i class="fas fa-calendar-check"></i> Booking Info</span>
        <h2 class="section-title mt-2">What We <span class="highlight">Need From You</span></h2>
        <ul style="list-style:none; display:flex; flex-direction:column; gap:1rem; margin-top:1.5rem;">
          <li style="display:flex; gap:1rem; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:rgba(10,125,232,0.15); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--primary); flex-shrink:0;">1</div>
            <div><strong>Music Playlist</strong> — preferred songs at least 7–14 days prior to event</div>
          </li>
          <li style="display:flex; gap:1rem; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:rgba(10,125,232,0.15); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--primary); flex-shrink:0;">2</div>
            <div><strong>Event Run Sheet</strong> — timings, speaker order, formalities (at least 7 days prior)</div>
          </li>
          <li style="display:flex; gap:1rem; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:rgba(10,125,232,0.15); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--primary); flex-shrink:0;">3</div>
            <div><strong>Venue Details</strong> — address, access times, power supply location</div>
          </li>
          <li style="display:flex; gap:1rem; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:rgba(10,125,232,0.15); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--primary); flex-shrink:0;">4</div>
            <div><strong>Event Contact</strong> — a nominated person for on-the-day coordination</div>
          </li>
        </ul>
      </div>
      <div class="reveal-right text-center">
        <div style="background:var(--bg-dark); border:1px solid var(--border); border-radius:var(--radius); padding:2.5rem;">
          <div class="equalizer" style="justify-content:center; margin-bottom:1.5rem;">
            <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
          </div>
          <h3 style="margin-bottom:1rem;">Ready to Book?</h3>
          <p style="color:var(--text-secondary); margin-bottom:1.5rem;">Contact us today to check availability and discuss your event.</p>
          <a href="/booking" class="btn btn-primary btn-pulse" style="width:100%; justify-content:center; margin-bottom:0.75rem;">
            <i class="fas fa-calendar-plus"></i> Book Now
          </a>
          <a href="tel:0467764778" class="btn btn-outline" style="width:100%; justify-content:center;">
            <i class="fas fa-phone"></i> 0467 764 778
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<style>
.dj-intro-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.dj-features-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 1.5rem;
}

.dj-feature {
  display: flex;
  align-items: flex-start;
  gap: 0.85rem;
  background: rgba(10,125,232,0.06);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem;
}

.dj-feature i { color: var(--primary); font-size: 1.3rem; margin-top:0.1rem; flex-shrink:0; }
.dj-feature strong { display: block; font-family: var(--font-heading); font-size: 0.9rem; margin-bottom: 0.2rem; }
.dj-feature span { color: var(--text-muted); font-size: 0.8rem; line-height: 1.5; }

.dj-visual {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.dj-logo-box {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 0.5rem;
  overflow: hidden;
}

.dj-contact-prompt {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem 1.5rem;
}

.dj-contact-prompt i { color: var(--primary); font-size: 1.5rem; }
.dj-contact-prompt strong { display: block; font-family: var(--font-heading); font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
.dj-contact-prompt a { color: var(--accent); font-size: 1.2rem; font-family: var(--font-heading); font-weight: 700; }

.included-card {
  background: var(--bg-dark);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.75rem;
  transition: all var(--transition);
}

.included-card:hover {
  border-color: rgba(0,212,255,0.3);
  transform: translateY(-4px);
}

.included-card i {
  font-size: 1.8rem;
  color: var(--primary);
  margin-bottom: 1rem;
  display: block;
}

.included-card h4 {
  font-family: var(--font-heading);
  font-size: 1rem;
  margin-bottom: 0.5rem;
}

.included-card p { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7; }

/* Wedding Timeline */
.wedding-timeline {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.wt-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.75rem;
  transition: all var(--transition);
  position: relative;
}

.wt-item:hover {
  border-color: rgba(0,212,255,0.3);
  transform: translateY(-4px);
}

.wt-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  background: rgba(10,125,232,0.15);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  color: var(--primary);
  margin-bottom: 1rem;
}

.wt-content h4 {
  font-family: var(--font-heading);
  font-size: 1rem;
  margin-bottom: 0.5rem;
}

.wt-content p { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7; }

@media (max-width: 768px) {
  .dj-intro-grid { grid-template-columns: 1fr; }
  .dj-features-grid { grid-template-columns: 1fr; }
  .wedding-timeline { grid-template-columns: 1fr; }
}
</style>
