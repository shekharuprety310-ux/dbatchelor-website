<style>
.service-detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}

.service-detail-grid.reverse { direction: rtl; }
.service-detail-grid.reverse > * { direction: ltr; }

.feature-list {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.65rem;
  margin: 1.5rem 0;
}

.feature-list li {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  color: var(--text-secondary);
  font-size: 0.95rem;
}

.feature-list i { color: var(--primary); }

.service-feature-box {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 3rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.service-feature-box::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--gradient-main);
}

.service-big-icon {
  font-size: 5rem;
  color: var(--primary);
  margin-bottom: 1.5rem;
  filter: drop-shadow(0 0 20px var(--glow));
}

.fa-spin-slow { animation: glow-rotate 8s linear infinite; }

.service-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
}

.equipment-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.equip-item {
  background: rgba(10,125,232,0.08);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.85rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
  font-family: var(--font-heading);
}

.equip-item i { color: var(--primary); font-size: 1.4rem; }

/* Light show */
.lighting-box { background: #030812; }

.light-show {
  position: relative;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.light-beam {
  position: absolute;
  bottom: 0;
  width: 3px;
  height: 100%;
  border-radius: 2px;
  transform-origin: bottom center;
  opacity: 0.7;
  animation: beam-sweep 4s ease-in-out infinite;
}

.beam-1 { background: linear-gradient(to top, #0a7de8, transparent); left: 30%; animation-delay: 0s; }
.beam-2 { background: linear-gradient(to top, #00d4ff, transparent); left: 45%; animation-delay: 0.5s; }
.beam-3 { background: linear-gradient(to top, #7b2fff, transparent); left: 55%; animation-delay: 1s; }
.beam-4 { background: linear-gradient(to top, #ff6b2b, transparent); left: 70%; animation-delay: 1.5s; }

@keyframes beam-sweep {
  0%, 100% { transform: rotate(-20deg); opacity: 0.3; }
  50% { transform: rotate(20deg); opacity: 0.9; }
}

.event-types-list { display: flex; flex-direction: column; gap: 0.65rem; text-align: left; }
.event-list-item {
  background: rgba(10,125,232,0.08);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  color: var(--text-secondary);
  font-family: var(--font-heading);
  font-size: 0.95rem;
  transition: all var(--transition);
}

.event-list-item:hover { border-color: var(--primary); color: var(--text-primary); }

@media (max-width: 768px) {
  .service-detail-grid { grid-template-columns: 1fr; gap: 2rem; }
  .service-detail-grid.reverse { direction: ltr; }
  .feature-list { grid-template-columns: 1fr; }
}

.service-logo-inline {
  margin: 1rem 0;
}

.service-logo-inline img {
  height: 60px;
  width: auto;
  filter: drop-shadow(0 0 10px var(--glow));
}
</style>
