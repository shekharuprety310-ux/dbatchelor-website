<style>
/* ── HOME PAGE SPECIFIC STYLES ── */

/* Hero */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding-top: 130px;
}

.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.35;
}

.orb-1 {
  width: 50vw; height: 50vw;
  max-width: 600px; max-height: 600px;
  background: radial-gradient(circle, #0a7de8 0%, transparent 70%);
  top: -200px; left: -200px;
  animation: float 8s ease-in-out infinite;
}

.orb-2 {
  width: 35vw; height: 35vw;
  max-width: 400px; max-height: 400px;
  background: radial-gradient(circle, #00d4ff 0%, transparent 70%);
  bottom: -100px; right: -100px;
  animation: float 10s ease-in-out infinite 2s;
}

.orb-3 {
  width: 25vw; height: 25vw;
  max-width: 300px; max-height: 300px;
  background: radial-gradient(circle, #1a4a9e 0%, transparent 70%);
  top: 50%; right: 20%;
  animation: float 7s ease-in-out infinite 1s;
}

.hero-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
  padding-top: 2rem;
  padding-bottom: 4rem;
}

.hero-content {
  animation: slide-in-left 0.9s ease forwards;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(4rem, 7vw, 7.5rem);
  letter-spacing: 0.03em;
  line-height: 1.05;
  margin-bottom: 1.5rem;
  display: flex;
  flex-direction: column;
  text-shadow: 0 0 80px rgba(94, 179, 255, 0.6);
}

.title-line-1 { color: var(--text-secondary); font-size: 0.7em; }
.title-line-2 { 
  font-size: 1em;
  background: linear-gradient(135deg, #5eb3ff, #33eaff, #7ac4ff);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: gradient-shift 3s ease infinite;
}
.title-line-3 { color: var(--text-secondary); font-size: 0.6em; }

.hero-subtitle {
  font-size: 1.25rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 1.5rem;
  max-width: 520px;
}

.hero-location {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--accent);
  font-size: 0.9rem;
  font-family: var(--font-heading);
  font-weight: 600;
  margin-bottom: 2rem;
}

.hero-location i { color: #ff4d4d; }

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}

.btn-lg {
  padding: 1rem 2.5rem;
  font-size: 1.05rem;
}

.hero-social {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--text-muted);
  font-size: 0.85rem;
  font-family: var(--font-heading);
}

.hero-social a {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 0.85rem;
  transition: all var(--transition);
}

.hero-social a:hover {
  background: var(--primary);
  border-color: var(--primary);
  color: white;
  transform: translateY(-2px);
}

/* Hero Visual */
.hero-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  animation: slide-in-right 0.9s ease forwards;
}

.hero-logo-wrapper {
  position: relative;
  z-index: 2;
}

.hero-logo-glow {
  position: absolute;
  inset: -30px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(10,125,232,0.3) 0%, transparent 70%);
  animation: pulse 3s ease-in-out infinite;
}

.hero-logo-container {
  background: transparent;
  border-radius: 50%;
  padding: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 100px rgba(10, 125, 232, 0.6), 0 0 60px rgba(0, 212, 255, 0.4);
  border: 4px solid rgba(10, 125, 232, 0.5);
  width: 90%;
  max-width: 400px;
  aspect-ratio: 1;
  overflow: hidden;
}

.hero-logo-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  border-radius: 50%;
  background: transparent;
  transition: all var(--transition);
}

.hero-logo-container:hover {
  transform: scale(1.02);
  box-shadow: 0 0 120px rgba(10, 125, 232, 0.7), 0 0 80px rgba(0, 212, 255, 0.5);
}

.hero-logo-img {
  width: 100%;
  height: 100%;
  max-width: 320px;
  aspect-ratio: 1;
  object-fit: contain;
  filter: drop-shadow(0 0 40px rgba(10, 125, 232, 0.7));
  transition: all var(--transition);
}

.orbit-ring {
  position: absolute;
  width: 90%;
  max-width: 420px;
  aspect-ratio: 1;
  border: 1px dashed rgba(0,212,255,0.2);
  border-radius: 50%;
}

.orbit-item {
  position: absolute;
  width: 3rem; height: 3rem;
  width: 5vw; height: 5vw;
  min-width: 40px; min-height: 40px;
  max-width: 44px; max-height: 44px;
  border-radius: 50%;
  background: var(--bg-card2);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: 1rem;
  font-size: 2vw;
  min-font-size: 0.9rem;
  max-font-size: 1.1rem;
  box-shadow: 0 4px 15px var(--glow);
}

.orbit-1 { top: -22px; left: 50%; transform: translateX(-50%); animation: orbit 10s linear infinite; }
.orbit-2 { right: -22px; top: 50%; transform: translateY(-50%); animation: orbit 10s linear infinite 2.5s; }
.orbit-3 { bottom: -22px; left: 50%; transform: translateX(-50%); animation: orbit 10s linear infinite 5s; }
.orbit-4 { left: -22px; top: 50%; transform: translateY(-50%); animation: orbit 10s linear infinite 7.5s; }

.hero-stats-mini {
  position: absolute;
  bottom: -60px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 1.5rem;
  background: rgba(13,22,40,0.9);
  backdrop-filter: blur(10px);
  border: 1px solid var(--border);
  border-radius: 50px;
  padding: 0.85rem 2rem;
}

.mini-stat { text-align: center; }
.mini-num {
  font-family: var(--font-display);
  font-size: 1.4rem;
  color: var(--accent);
  display: block;
}
.mini-label {
  font-size: 0.7rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* Scroll indicator */
.hero-scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-muted);
  font-size: 0.75rem;
  font-family: var(--font-heading);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  animation: fade-in 1s ease 1.5s both;
}

.scroll-mouse {
  width: 24px; height: 38px;
  border: 2px solid rgba(255,255,255,0.2);
