<%- include('partials/header') %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content">
      <div class="breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Book Now</span></div>
      <h1 class="text-gradient">Book Your Event</h1>
      <p style="color:var(--text-secondary); max-width:600px; margin: 1rem auto 0; font-size:1.1rem;">
        Fill in your event details and we'll be in touch within 24 hours to confirm your booking.
      </p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="booking-layout">

      <!-- Booking Form -->
      <div class="booking-form-wrap reveal-left">
        <form action="/booking" method="POST" class="booking-form">
          <div class="form-section-title">
            <i class="fas fa-user"></i> Your Details
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Full Name *</label>
              <input type="text" name="name" class="form-control" placeholder="Full Name" required>
            </div>
            <div class="form-group">
              <label class="form-label">Phone *</label>
              <input type="tel" name="phone" class="form-control" placeholder="0400 000 000" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Email Address *</label>
            <input type="email" name="email" class="form-control" placeholder="your@email.com" required>
          </div>

          <div class="form-section-title mt-3">
            <i class="fas fa-calendar-alt"></i> Event Details
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Event Type *</label>
              <select name="eventType" class="form-control" required>
                <option value="">— Select event type —</option>
                <option>Wedding / Reception</option>
                <option>Birthday Party</option>
                <option>Corporate Event</option>
                <option>School Formal</option>
                <option>Festival / Outdoor</option>
                <option>Private Party</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Expected Guests</label>
              <select name="guests" class="form-control">
                <option>Under 50</option>
                <option>50 - 100</option>
                <option>100 - 200</option>
                <option>200 - 300</option>
                <option>300+</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Event Date *</label>
              <input type="date" name="eventDate" class="form-control" required>
            </div>
            <div class="form-group">
              <label class="form-label">Start Time</label>
              <input type="time" name="startTime" class="form-control">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Finish Time</label>
              <input type="time" name="finishTime" class="form-control">
            </div>
            <div class="form-group">
              <label class="form-label">Venue / Location *</label>
              <input type="text" name="venue" class="form-control" placeholder="Venue name or suburb" required>
            </div>
          </div>

          <div class="form-section-title mt-3">
            <i class="fas fa-music"></i> Services Required
          </div>
          <div class="service-checkboxes">
            <label class="checkbox-item">
              <input type="checkbox" name="services" value="dj">
              <span class="checkbox-custom"></span>
              <i class="fas fa-compact-disc"></i> DJ Services
            </label>
            <label class="checkbox-item">
              <input type="checkbox" name="services" value="mc">
              <span class="checkbox-custom"></span>
              <i class="fas fa-microphone"></i> MC Services
            </label>
            <label class="checkbox-item">
              <input type="checkbox" name="services" value="audio">
              <span class="checkbox-custom"></span>
              <i class="fas fa-volume-up"></i> Audio / Sound System
            </label>
            <label class="checkbox-item">
              <input type="checkbox" name="services" value="lighting">
              <span class="checkbox-custom"></span>
              <i class="fas fa-lightbulb"></i> Lighting Effects
            </label>
            <label class="checkbox-item">
              <input type="checkbox" name="services" value="party-hire">
              <span class="checkbox-custom"></span>
              <i class="fas fa-star"></i> Party Equipment Hire
            </label>
            <label class="checkbox-item">
              <input type="checkbox" name="services" value="event-management">
              <span class="checkbox-custom"></span>
              <i class="fas fa-calendar-check"></i> Event Management
            </label>
          </div>

          <div class="form-group mt-3">
            <label class="form-label">Additional Notes</label>
            <textarea name="notes" class="form-control" placeholder="Music preferences, special requests, access requirements..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-pulse mt-2" style="width:100%; justify-content:center; font-size:1.05rem;">
            <i class="fas fa-calendar-plus"></i> Submit Booking Request
          </button>
          <p style="text-align:center; color:var(--text-muted); font-size:0.85rem; margin-top:1rem;">
            We'll contact you within 24 hours to confirm your booking and discuss pricing.
          </p>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="booking-sidebar reveal-right">
        <div class="sidebar-card">
          <h4><i class="fas fa-info-circle"></i> Booking Process</h4>
          <div class="process-steps">
            <div class="process-step">
              <div class="step-num">1</div>
              <div>
                <strong>Submit Request</strong>
                <span>Fill out the form with your event details</span>
              </div>
            </div>
            <div class="process-step">
              <div class="step-num">2</div>
              <div>
                <strong>We'll Call You</strong>
                <span>We'll contact you within 24 hours to discuss your event</span>
              </div>
            </div>
            <div class="process-step">
              <div class="step-num">3</div>
              <div>
                <strong>Custom Quote</strong>
                <span>Receive a tailored quote for your specific requirements</span>
              </div>
            </div>
            <div class="process-step">
              <div class="step-num">4</div>
              <div>
                <strong>Secure Your Date</strong>
                <span>Pay deposit to confirm your booking</span>
              </div>
            </div>
          </div>
        </div>

        <div class="sidebar-card mt-3">
          <h4><i class="fas fa-phone"></i> Contact Directly</h4>
          <p style="color:var(--text-muted); font-size:0.9rem; margin-bottom:1rem;">Prefer to talk? Call or message us directly.</p>
          <a href="tel:0467764778" class="btn btn-primary" style="width:100%; justify-content:center; margin-bottom:0.75rem;">
            <i class="fas fa-phone"></i> 0467 764 778
          </a>
          <a href="mailto:cassandra@batchelorenterprises.com" class="btn btn-outline" style="width:100%; justify-content:center;">
            <i class="fas fa-envelope"></i> Send Email
          </a>
        </div>

        <div class="sidebar-card mt-3">
          <h4><i class="fas fa-credit-card"></i> Payment Methods</h4>
          <ul style="list-style:none; color:var(--text-muted); font-size:0.9rem; display:flex; flex-direction:column; gap:0.5rem;">
            <li><i class="fas fa-check" style="color:var(--primary); margin-right:0.5rem;"></i>Bank Transfer (BSB: 013711 | Acc: 179678283)</li>
            <li><i class="fas fa-check" style="color:var(--primary); margin-right:0.5rem;"></i>PayID: 0467 764 778</li>
            <li><i class="fas fa-check" style="color:var(--primary); margin-right:0.5rem;"></i>Cash</li>
            <li><i class="fas fa-check" style="color:var(--primary); margin-right:0.5rem;"></i>Card Payments</li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>

<style>
.booking-layout {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 3rem;
  align-items: start;
}

.booking-form-wrap {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2.5rem;
}

.form-section-title {
  font-family: var(--font-heading);
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.65rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.service-checkboxes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.65rem;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  background: rgba(10,125,232,0.06);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  cursor: pointer;
  color: var(--text-secondary);
  font-family: var(--font-heading);
  font-size: 0.9rem;
  transition: all var(--transition);
}

.checkbox-item:hover, .checkbox-item:has(input:checked) {
  border-color: var(--primary);
  background: rgba(10,125,232,0.12);
  color: var(--accent);
}

.checkbox-item input { display: none; }
.checkbox-custom {
  width: 18px; height: 18px;
  border: 2px solid var(--border);
  border-radius: 4px;
  flex-shrink: 0;
  transition: all var(--transition);
}

.checkbox-item:has(input:checked) .checkbox-custom {
  background: var(--primary);
  border-color: var(--primary);
}

.checkbox-item i { color: var(--primary); }

.sidebar-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.75rem;
}

.sidebar-card h4 {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.process-steps { display: flex; flex-direction: column; gap: 1rem; }

.process-step {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.step-num {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: var(--gradient-main);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.9rem;
  flex-shrink: 0;
}

.process-step strong {
  display: block;
  font-family: var(--font-heading);
  font-size: 0.95rem;
  margin-bottom: 0.2rem;
}

.process-step span {
  color: var(--text-muted);
  font-size: 0.85rem;
  line-height: 1.5;
}

@media (max-width: 768px) {
  .booking-layout { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .service-checkboxes { grid-template-columns: 1fr; }
}
</style>
