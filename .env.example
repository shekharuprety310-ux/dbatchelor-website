# D Batchelor Enterprises Website - Environment Configuration
PORT=8080

# Email configuration for receiving form submissions
# Note: For Gmail, you need an "App Password", not your regular password
# 1. Go to Google Account → Security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords (search in settings)
# 4. Create new app password for "Mail"
# 5. Use that 16-character password below

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=cassandra@batchelorenterprises.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=cassandra@batchelorenterprises.com
EMAIL_TO=cassandra@batchelorenterprises.com

# Alternative: Use Gmail with App Password
# Generate app password at: https://myaccount.google.com/apppasswords